# GitHub
GITHUB_URL=https://github.com/citizenweb3/validatorinfo
GITHUB_RUNNER_TOKEN_BUILDER=
GITHUB_RUNNER_TOKEN_CONTENT=
GITHUB_RUNNER_TOKEN_CONTENT_CW3=
GITHUB_PERSONAL_ACCESS_TOKEN=

# Claude Code auth (from setup-token)
CLAUDE_CODE_OAUTH_TOKEN=
CLAUDE_ACCOUNT_UUID=
CLAUDE_EMAIL=
CLAUDE_ORG_UUID=

# DeepContext MCP (semantic code search)
WILDCARD_API_KEY=

# Database
DATABASE_URL=postgresql://user:password@host.docker.internal:5432/validatorinfo_db?schema=public
EVENTS_DATABASE_URL=postgresql://user:password@host.docker.internal:5433/validatorinfo_events_db?schema=public

# Figma (optional, for builder)
FIGMA_ACCESS_TOKEN=

# RAG API (shared secret for internal RAG search endpoint)
RAG_API_TOKEN=
# When agents-infrastructure runs in a separate docker-compose project from validatorinfo,
# use the published frontend port on the host instead of the internal `frontend` DNS name.
RAG_API_URL=http://host.docker.internal:3000

# ValidatorInfo content agent (seo-vi)
TWITTER_API_KEY=
TWITTER_API_SECRET=
TWITTER_BEARER_TOKEN=
TWITTER_OAUTH2_ACCESS_TOKEN=
TWITTER_ACCESS_TOKEN=
TWITTER_ACCESS_TOKEN_SECRET=
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHANNEL_ID=
DISCORD_WEBHOOK_URL=

# Citizen Web3 content agent (seo-cw3)
CW3_TWITTER_API_KEY=
CW3_TWITTER_API_SECRET=
CW3_TWITTER_BEARER_TOKEN=
CW3_TWITTER_OAUTH2_ACCESS_TOKEN=
CW3_TWITTER_ACCESS_TOKEN=
CW3_TWITTER_ACCESS_TOKEN_SECRET=
CW3_TELEGRAM_BOT_TOKEN=
CW3_TELEGRAM_CHANNEL_ID=
CW3_DISCORD_WEBHOOK_URL=
CW3_RAG_API_URL=http://host.docker.internal:3000
