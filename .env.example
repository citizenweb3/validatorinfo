# ============================================
# Database Configuration
# ============================================

# Main Database
DATABASE_URL="postgresql://validatorinfo_user:password@localhost:5432/validatorinfo_db?schema=public"
POSTGRES_DB="validatorinfo_db"
POSTGRES_USER="validatorinfo_user"
POSTGRES_PASSWORD="password"

# Events Database (persists across main DB resets)
EVENTS_DATABASE_URL="postgresql://validatorinfo_events_user:events_password@localhost:5433/validatorinfo_events_db?schema=public"
EVENTS_POSTGRES_DB="validatorinfo_events_db"
EVENTS_POSTGRES_USER="validatorinfo_events_user"
EVENTS_POSTGRES_PASSWORD="events_password"

# ============================================
# Application Configuration
# ============================================

SERVER_PORT="3000"
INDEXER_PORT="3001"

PUBLIC_URL="http://localhost:3000"

# External APIs
VALIDATORS_APP_TOKEN=""
RAG_API_TOKEN=""
SKIP_API_KEY=""
GITHUB_API_TOKEN=""
X_API_KEY=""
X_API_KEY_SECRET=""
ETHEREUM_RPC_KEY=""
SEPOLIA_RPC_KEY=""

# Aztec L2 Indexer API (server-side only, no NEXT_PUBLIC_ prefix)
AZTEC_INDEXER_BASE_URL="http://localhost:8000"
# Optional: API key for authentication (if required by your indexer)
# AZTEC_INDEXER_API_KEY=""

# ============================================
# OpenTelemetry Configuration
# ============================================

# Enable/disable telemetry (true/false)
OTEL_ENABLED=false

# Service names (optional, defaults are set in docker-compose.dev.yml)
# OTEL_SERVICE_NAME_FRONTEND=validatorinfo-frontend
# OTEL_SERVICE_NAME_INDEXER=validatorinfo-indexer

# --- Scenario 1: Local Development (default) ---
# Run observability stack locally with docker-compose-observability.yml
# OTEL_EXPORTER_OTLP_ENDPOINT=http://alloy:4317
# PYROSCOPE_SERVER_URL=http://pyroscope:4040

# --- Scenario 2: Production with Remote Monitoring Server ---
# Point to external Grafana Alloy on separate server (e.g., monitoring.example.com)
# OTEL_EXPORTER_OTLP_ENDPOINT=https://monitoring.example.com:4317
# PYROSCOPE_SERVER_URL=https://monitoring.example.com:4040
# Note: Configure TLS certificates and authentication in instrumentation.ts if needed

# --- Scenario 3: Grafana Cloud (SaaS) ---
# OTEL_EXPORTER_OTLP_ENDPOINT=https://otlp-gateway-prod-eu-west-0.grafana.net/otlp
# PYROSCOPE_SERVER_URL=https://profiles-prod-001.grafana.net
# Note: Requires API key configuration

# OpenTelemetry SDK log level (info/debug/error)
OTEL_LOG_LEVEL="info"

#GEMINI API KEY
GOOGLE_GENERATIVE_AI_API_KEY=

# ============================================
# RAG API Configuration
# ============================================

RAG_API_TOKEN=""
RAG_API_URL=""

# ============================================
# CW3 Content Agent (Citizen Web3)
# ============================================

CW3_TWITTER_API_KEY=""
CW3_TWITTER_API_SECRET=""
CW3_TWITTER_BEARER_TOKEN=""
CW3_TWITTER_ACCESS_TOKEN=""
CW3_TWITTER_ACCESS_TOKEN_SECRET=""
CW3_TELEGRAM_BOT_TOKEN=""
CW3_TELEGRAM_CHANNEL_ID=""
CW3_DISCORD_WEBHOOK_URL=""
GITHUB_RUNNER_TOKEN_CONTENT_CW3=""
